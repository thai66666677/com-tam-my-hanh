{
  "rewrites": [
    { "source": "/",                   "destination": "/frontend/index.html" },
    { "source": "/menu",               "destination": "/frontend/menu.html" },
    { "source": "/order",              "destination": "/frontend/order.html" },
    { "source": "/account",            "destination": "/frontend/account.html" },
    { "source": "/history",            "destination": "/frontend/history.html" },
    { "source": "/reviews",            "destination": "/frontend/reviews.html" },
    { "source": "/admin",              "destination": "/admin/login.html" },
    { "source": "/admin/dashboard",    "destination": "/admin/dashboard.html" },
    { "source": "/admin/menu-manager", "destination": "/admin/menu-manager.html" },
    { "source": "/admin/stats",        "destination": "/admin/stats.html" },
    { "source": "/admin/settings",     "destination": "/admin/settings.html" },

    { "source": "/sitemap.xml",        "destination": "/frontend/sitemap.xml" },
    { "source": "/robots.txt",         "destination": "/frontend/robots.txt" }
