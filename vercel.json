{
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/menu", "destination": "/frontend/menu.html" },
    { "source": "/order", "destination": "/frontend/order.html" },
    { "source": "/account", "destination": "/frontend/account.html" },
    { "source": "/history", "destination": "/frontend/history.html" },
    { "source": "/reviews", "destination": "/frontend/reviews.html" },
    { "source": "/admin", "destination": "/admin/login.html" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/frontend/(.*)", "destination": "/frontend/$1" }
  ]
}